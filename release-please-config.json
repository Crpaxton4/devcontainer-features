{
    "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
    "packages": {
        ".": {
            "release-type": "simple",
            "component": "personal-features",
            "extra-files": [
                {
                    "type": "json",
                    "path": "devcontainer-features/src/personal-features/devcontainer-feature.json",
                    "jsonpath": "$.version"
                },
                {
                    "type": "toml",
                    "path": "libraries/odoo_sdk/pyproject.toml",
                    "jsonpath": "$.project.version"
                }
            ]
        }
    }
}
