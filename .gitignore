
# Ignore everything by default and explicitly whitelist known files
/*
/.*/

# Keep the gitignore itself
!/.gitignore

# known solution directories (include their contents)
!/.devcontainer/
!/.devcontainer/**

!/docs/
!/docs/**

# Generated by sphinx-build / sphinx-apidoc, regenerated on every build
docs/build/
docs/source/api/

!/commands/
!/commands/**


!/examples/
!/examples/**
!/src/
!/src/**

!/tests/
!/tests/**

# Whitelist project config files
!/cosmic-ray.toml
!/pyproject.toml
!/uv.lock

# General Development Tooling
!/tools/
!/tools/**

# VS Code workspace settings
!/.vscode/
!/.vscode/**

!/requirements/
!/requirements/**
!requirements.txt

# Make
!Makefile


# Specific files to exclude
**/__pycache__/
*.py[cod]
