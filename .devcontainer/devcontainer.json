{
  "image": "mcr.microsoft.com/devcontainers/python:3.13-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:3": {
      "installDockerBuildx": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    // pandoc is required by nbsphinx to convert walkthrough.ipynb during
    // `make html`; without it the docs build raises PandocMissing. The CI docs
    // workflow (odoo-sdk-docs.yaml) installs pandoc separately, so this entry
    // only covers local builds inside the devcontainer.
    "ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {
      "packages": "pandoc"
    },
    "ghcr.io/jsburckhardt/devcontainer-features/uv:1": {}
  },
  // Pinned to match DEVCONTAINERS_CLI_VERSION in .github/workflows/test.yaml.
  // Refresh both together when bumping (no shared source across the two files).
  "updateContentCommand": "npm install -g @devcontainers/cli@0.87.0",
  "postCreateCommand": "cd libraries/odoo_sdk && uv sync --group dev",
  "remoteEnv": {
    "UV_PROJECT_ENVIRONMENT": "${containerWorkspaceFolder}/.venv"
  },
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.black-formatter",
        "ms-python.debugpy",
        "ms-python.vscode-python-envs",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.vscode-jupyter-slideshow",
        "njpwerner.autodocstring",
        "coderabbit.coderabbit-vscode",
        "ms-python.isort"
      ],
      "settings": {
        "json.schemas": [
          {
            "fileMatch": [
              "*/devcontainer-feature.json"
            ],
            "url": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainerFeature.schema.json"
          }
        ],
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.analysis.typeCheckingMode": "strict",
        "python.languageServer": "Pylance",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.formatOnSave": true,
          "editor.quickSuggestions": {
            "comments": "on",
            "other": "on",
            "strings": "on"
          },
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        },
        "isort.args": [
          "--profile",
          "black"
        ],
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "python.testing.cwd": "${workspaceFolder}/libraries/odoo_sdk",
        "python.testing.pytestArgs": [
          "tests"
        ],
        "testing.coverageToolbarEnabled": false,
        "testing.gutterEnabled": true,
        "testing.showCoverageInExplorer": true,
        "explorer.decorations.badges": true,
        "explorer.decorations.colors": true
      }
    }
  }
}
