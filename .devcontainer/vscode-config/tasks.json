{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "odoo_sdk: Prepare environment",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "uv venv --allow-existing .venv && uv sync"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "odoo_sdk: Run unit tests + coverage",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "uv run coverage run -m unittest -v && uv run coverage report && uv run coverage html"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "odoo_sdk: Cosmic Ray init session",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "uv run ./scripts/cosmic-ray-init.sh \"session\""
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "hide": false,
      "presentation": {
        "focus": false,
        "showReuseMessage": false,
        "panel": "shared",
        "group": "mutation-test"
      },
      "problemMatcher": []
    },
    {
      "label": "odoo_sdk: Cosmic Ray baseline",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "uv run ./scripts/cosmic-ray-baseline.sh \"session\""
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "hide": false,
      "presentation": {
        "focus": false,
        "showReuseMessage": false,
        "panel": "shared",
        "group": "mutation-test"
      },
      "problemMatcher": []
    },
    {
      "label": "odoo_sdk: Cosmic Ray exec session",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "uv run ./scripts/cosmic-ray-exec.sh \"session\""
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "hide": false,
      "presentation": {
        "focus": false,
        "showReuseMessage": false,
        "panel": "shared",
        "group": "mutation-test"
      },
      "problemMatcher": []
    },
    {
      "label": "odoo_sdk: Cosmic Ray report",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "uv run ./scripts/cosmic-ray-report.sh \"session\""
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "hide": false,
      "presentation": {
        "focus": false,
        "showReuseMessage": false,
        "panel": "shared",
        "group": "mutation-test"
      },
      "problemMatcher": []
    },
    {
      "label": "Mutation Test",
      "dependsOrder": "sequence",
      "dependsOn": [
        "odoo_sdk: Cosmic Ray init session",
        "odoo_sdk: Cosmic Ray baseline",
        "odoo_sdk: Cosmic Ray exec session",
        "odoo_sdk: Cosmic Ray report"
      ],
      "presentation": {
        "focus": true,
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false,
        "group": "mutation-test"
      },
      "problemMatcher": []
    }
  ]
}
