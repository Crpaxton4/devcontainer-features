{
    "with_node_and_gh": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "ghcr.io/devcontainers/features/node:1": {
                "version": "lts"
            },
            "ghcr.io/devcontainers/features/github-cli:1": {},
            "personal-features": {}
        },
        "remoteUser": "vscode"
    },
    "on_odoo_base_image": {
        "image": "odoo:19",
        "features": {
            "ghcr.io/devcontainers/features/node:1": {
                "version": "lts"
            },
            "personal-features": {}
        },
        "remoteUser": "root"
    },
    "on_odoo18_base_image": {
        "image": "odoo:18",
        "features": {
            "ghcr.io/devcontainers/features/node:1": { "version": "lts" },
            "personal-features": {}
        },
        "remoteUser": "root"
    },
    "on_odoo17_base_image": {
        "image": "odoo:17",
        "features": {
            "ghcr.io/devcontainers/features/node:1": { "version": "lts" },
            "personal-features": {}
        },
        "remoteUser": "root"
    },
    "on_odoo16_base_image": {
        "image": "odoo:16",
        "features": {
            "ghcr.io/devcontainers/features/node:1": { "version": "lts" },
            "personal-features": {}
        },
        "remoteUser": "root"
    }
}
