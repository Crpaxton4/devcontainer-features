#!/usr/bin/env bash
# claude-event-hook — Claude Code lifecycle hook shim that records one event
# into odoo-sdk local state via `odoo-sdk log-event`.
#
# Invoked by every feature-owned hook entry in $CLAUDE_CONFIG_DIR/settings.json
# with the hook event name as its single argument, e.g.
#
#     claude-event-hook PreToolUse
#
# Claude Code passes the hook's JSON payload on stdin (see the hooks reference:
# every event carries `hook_event_name`, `session_id`, `cwd`; PreToolUse/
# PostToolUse also carry `tool_name` and `tool_input`; Subagent* carry
# `agent_type`/`agent_id`). This shim extracts a compact subject, resolves the
# session branch from `cwd` for task attribution (#574), and forwards a trimmed
# payload carrying the hook event type and session id (#575) to the SDK, which
# resolves the HOST-provisioned CENTRAL tracker DB (#369 — one DB shared by every
# project, located via ODOO_TASK_TRACKER_DIR) and appends one row to its `events`
# table.
#
# CONTRACT — this must never disrupt a Claude Code session:
#   * ALWAYS exit 0 (a nonzero exit, or exit 2 with stderr, is interpreted by
#     the hooks contract as blocking/denying the action — forbidden here).
#   * Never write to stdout: for PreToolUse a JSON object on stdout can carry a
#     permission decision, and even plain text is surfaced to the session.
#     Diagnostics go to stderr only.
#   * No-op cleanly when `odoo-sdk` is not installed (e.g. Python <3.10 images).
#   * Bounded runtime so a slow/hung DB can't stall the agent.
#
# PreToolUse for `mcp__odoo-mcp__*` tools is skipped: the odoo MCP server
# already logs those dispatches server-side (#326/#340), so logging them here
# too would double-count them.

# Deliberately NOT `set -e`/`set -o pipefail`: a failure anywhere in this shim
# must degrade to "no event logged", never to a nonzero exit that the hook
# contract would read as a block. Errors are handled explicitly instead.
set -u

HOOK_NAME="${1:-Unknown}"

# Read the hook JSON payload from stdin. `cat` with no controlling input would
# hang, but Claude Code always provides stdin for hooks; guard with a short
# read timeout anyway so a misconfigured manual invocation can't wedge.
STDIN_JSON=""
if [ ! -t 0 ]; then
    STDIN_JSON="$(timeout 5 cat 2>/dev/null || true)"
fi

# Nothing to do if the SDK CLI isn't on PATH (e.g. base image with Python <3.10
# where the wheel was skipped). Silent, successful no-op.
command -v odoo-sdk >/dev/null 2>&1 || exit 0

# jq drives payload extraction; without it, fall back to logging the bare event
# with no subject rather than failing.
HAVE_JQ=0
command -v jq >/dev/null 2>&1 && HAVE_JQ=1

# tool_name is only meaningful for the tool-call events; pull it out once so we
# can both build the subject and enforce the mcp__odoo-mcp__* exclusion.
TOOL_NAME=""
if [ "$HAVE_JQ" -eq 1 ] && [ -n "$STDIN_JSON" ]; then
    TOOL_NAME="$(printf '%s' "$STDIN_JSON" | jq -r '.tool_name // empty' 2>/dev/null || true)"
fi

# The odoo MCP server logs its own tool dispatches server-side (#326/#340).
# Skipping PreToolUse for those tools here avoids double-logging. install.sh
# registers the server under the key `odoo-mcp` (its console-script name), and
# Claude Code namespaces MCP tools as `mcp__<server-key>__<tool>` with the key's
# hyphens PRESERVED, so the real tool names are `mcp__odoo-mcp__*`. Earlier globs
# `mcp__odoo__*` (pre-#529) and `mcp__odoo-sdk__*` (#529) never fired against the
# real `odoo-mcp` key, so every odoo call was double-counted. Keep this prefix in
# lockstep with the `claude mcp add ... odoo-mcp` key in install.sh.
# Belt-and-braces alongside the settings.json matcher, which matches all tools.
case "$HOOK_NAME" in
    PreToolUse|PostToolUse)
        case "$TOOL_NAME" in
            mcp__odoo-mcp__*) exit 0 ;;
        esac
        ;;
esac

# Build a compact, human-readable subject per event kind.
SUBJECT=""
if [ "$HAVE_JQ" -eq 1 ] && [ -n "$STDIN_JSON" ]; then
    case "$HOOK_NAME" in
        PreToolUse|PostToolUse)
            SUBJECT="$TOOL_NAME"
            ;;
        SubagentStart|SubagentStop)
            SUBJECT="$(printf '%s' "$STDIN_JSON" | jq -r '.agent_type // empty' 2>/dev/null || true)"
            ;;
        SessionStart)
            SUBJECT="$(printf '%s' "$STDIN_JSON" | jq -r '.source // empty' 2>/dev/null || true)"
            ;;
    esac
fi

# Forward a trimmed payload: the session id and hook event type (the two
# triage-context fields with no dedicated event column, #575) plus the tool/agent
# identifiers, keeping the row small and free of prompt/tool_input contents (which
# can be large or sensitive). The hook event type is taken from $HOOK_NAME (the
# argv the settings.json matcher passes), not the JSON, so it is always present
# and authoritative even when a payload omits `hook_event_name`. Any jq failure
# degrades to no payload.
PAYLOAD=""
if [ "$HAVE_JQ" -eq 1 ] && [ -n "$STDIN_JSON" ]; then
    PAYLOAD="$(printf '%s' "$STDIN_JSON" \
        | jq -c --arg hook "$HOOK_NAME" \
            '{session_id, tool_name, agent_type, agent_id, source, hook_event_name: $hook} | with_entries(select(.value != null))' \
        2>/dev/null || true)"
fi

# Resolve the session branch so the event can be attributed to its task (#574).
# The session branch follows the `<task-id>#<slug>` convention start_task writes,
# so the SDK recovers the task id from it when no FSM run is active — otherwise
# the event falls through to triage. Read it from the hook JSON's `cwd` (the
# authoritative session directory, which the agent may have cd'd into, away from
# where Claude Code spawned this hook) rather than the shim's own $PWD. Purely
# best-effort and bounded: a non-repo cwd, a detached HEAD, or a missing `cwd`
# leaves BRANCH empty and the SDK falls back to resolving it from its own cwd for
# provenance only. Runs only for non-excluded events (mcp__odoo-mcp__* already
# exited above), so an excluded tool never spends a git call.
CWD=""
if [ "$HAVE_JQ" -eq 1 ] && [ -n "$STDIN_JSON" ]; then
    CWD="$(printf '%s' "$STDIN_JSON" | jq -r '.cwd // empty' 2>/dev/null || true)"
fi
BRANCH=""
if [ -n "$CWD" ]; then
    BRANCH="$(timeout 2 git -C "$CWD" symbolic-ref --short HEAD 2>/dev/null || true)"
fi

# Assemble args. `--attach-active-run` associates the event with the task id of
# EVERY non-stale active FSM run in the central tracker DB (issue #327 open
# question 1), falling back to untargeted when there is none. Attribution is
# CROSS-PROJECT, not per-project: since #388 the DB is shared by every project
# and the flag applies no repo filter, so a hook firing in project A attaches to
# an active run started in project B. That is the SDK's intended behaviour —
# do not describe this as scoped to the current project.
set -- log-event --source "claude:$HOOK_NAME" --attach-active-run
[ -n "$SUBJECT" ] && set -- "$@" --subject "$SUBJECT"
[ -n "$BRANCH" ] && set -- "$@" --branch "$BRANCH"
[ -n "$PAYLOAD" ] && set -- "$@" --payload "$PAYLOAD"

# Fire-and-forget: fork the SDK call into a detached background subshell and
# return immediately, so the hook never makes a tool call wait on cat+jq+the
# Python interpreter+SQLite (hundreds of ms; up to the 10s timeout worst case).
# The payload is already fully captured in STDIN_JSON above, so nothing here
# depends on stdin staying open. The extra subshell wrapper `( ... & )` reparents
# the job to init and suppresses any job-control notice, keeping stdout clean.
# Runtime is still bounded by `timeout`, and any nonzero exit is swallowed inside
# the background job — this shim itself always exits 0.
( timeout 10 odoo-sdk "$@" >/dev/null 2>&1 & ) 2>/dev/null

exit 0
