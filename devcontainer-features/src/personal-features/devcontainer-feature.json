{
    "name": "Personal Features",
    "id": "personal-features",
    "version": "1.18.1",
    "description": "Installs the owner's personal dev container tooling: Claude Code (wrapped to auto-connect to the IDE), productivity/navigation CLIs, gitleaks secret scanning, machine-wide Conventional Commits + secret-scanning git hooks, and shell enhancements (Starship, aliases, persisted history) - and persists Claude's, the gh CLI's, and shell history config across container rebuilds and across projects. This is the owner's personal, opinionated setup, not a configurable toolkit, so it has no options: tools are added or removed outright rather than gated behind flags.",
    "options": {},
    "dependsOn": {
        "ghcr.io/devcontainers/features/node:1": {}
    },
    "installsAfter": [
        "ghcr.io/devcontainers/features/node",
        "ghcr.io/devcontainers/features/github-cli",
        "ghcr.io/devcontainers/features/common-utils"
    ],
    "containerEnv": {
        "CLAUDE_CONFIG_DIR": "/usr/local/share/claude-home",
        "GH_CONFIG_DIR": "/usr/local/share/gh-cli-config",
        "DISABLE_AUTOUPDATER": "1",
        "ODOO_SDK_CONFIG": "/usr/local/share/odoo-sdk-config",
        "MEMPAL_DIR": "/workspaces",
        "PR_AUTOMATION_CONFIG_DIR": "/usr/local/share/pr-automation",
        "CODERABBIT_CONFIG_DIR": "/usr/local/share/coderabbit-config"
    },
    "mounts": [
        {
            "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.claude",
            "target": "/usr/local/share/claude-home",
            "type": "bind"
        },
        {
            "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.config/gh",
            "target": "/usr/local/share/gh-cli-config",
            "type": "bind"
        },
        {
            "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.config/odoo_sdk",
            "target": "/usr/local/share/odoo-sdk-config",
            "type": "bind"
        },
        {
            "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.config/pr-automation",
            "target": "/usr/local/share/pr-automation",
            "type": "bind"
        },
        {
            "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.config/coderabbit",
            "target": "/usr/local/share/coderabbit-config",
            "type": "bind"
        },
        {
            "source": "${localEnv:HOME}${localEnv:USERPROFILE}/.config/devcontainer/shell-history",
            "target": "/usr/local/share/shell-history",
            "type": "bind"
        }
    ]
}
